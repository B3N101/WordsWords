datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

generator client {
  provider = "prisma-client-js"
}

// AUTH MODELS
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// MAIN MODELS
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role    Role    @default(STUDENT)
  classes Class[] @relation("UserClasses")

  wordMasteries           UserWordMastery[]
  userWordsListProgresses UserWordsListProgress[]
  quizAttempts            QuizAttempt[]
}

model Class {
  classId       String   @id @default(cuid())
  className     String
  teacherId     String
  students      User[]   @relation("UserClasses")
  semesterStart DateTime
  semesterEnd   DateTime

  assignedWordsLists AssignedWordsList[]
}

model Word {
  wordId               String       @id @default(cuid())
  word                 String
  partOfSpeech         partOfSpeech
  gradeLevel           Grade
  context              String
  definition           String
  incorrectDefinitions String[]
  exampleSentence      String
  incorrectFillIns      String[]
  wordListNumber       Int?
  rankWithinList       Int?

  wordsList WordsList? @relation(fields: [listId], references: [id])
  listId    String?

  userWordMasteries UserWordMastery[]
  questions         Question[]
}

model WordsList {
  id     String @id @default(cuid())
  number Int // Number of List

  words    Word[]
  quizzes  Quiz[]
  assigned AssignedWordsList[]
}

model AssignedWordsList {
  id          String    @id @default(cuid())
  class       Class     @relation(fields: [classId], references: [classId])
  classId     String
  wordsList   WordsList @relation(fields: [wordsListId], references: [id])
  wordsListId String
  startDate   DateTime
  endDate     DateTime

  userProgresses UserWordsListProgress[]
}

model UserWordsListProgress {
  id            String @id @default(cuid())
  user          User   @relation(fields: [userId], references: [id])
  userId        String
  assignment    AssignedWordsList @relation(fields: [assignedWordsListId], references: [id])
  assignedWordsListId String
  startDate     DateTime
  endDate       DateTime
  completed     Boolean @default(false)

  quizAttempts QuizAttempt[]

  // @@id(name: "UserWordsListProgressId", [userId, assignedWordsListId]) -> don't know why this would be better or worse?
}

model UserWordMastery {
  id           String @id @default(cuid())
  word         Word   @relation(fields: [wordId], references: [wordId])
  wordId       String

  user         User   @relation(fields: [userId], references: [id])
  userId       String

  masteryScore Float

  questionAttempts UserQuestionAttempt[]

  @@unique([wordId, userId])
}

model Quiz {
  id          String     @id @default(cuid())
  quizName    String?
  quizType    QuizType
  wordsList   WordsList  @relation(fields: [wordsListId], references: [id], onDelete: Cascade)
  wordsListId String
  questions   Question[]

  quizAttempts QuizAttempt[]
}

model QuizAttempt {
  id          String                @id @default(cuid())
  quiz        Quiz                  @relation(fields: [quizId], references: [id])
  quizId      String
  user        User                  @relation(fields: [userId], references: [id])
  userId      String
  progress    UserWordsListProgress @relation(fields: [progressId], references: [id])
  progressId  String
  completed   Boolean               @default(false)
  score       Float                 @default(0)
  startedAt   DateTime              @default(now())
  completedAt DateTime?

  questionAttempts UserQuestionAttempt[]
}

model Question {
  id            String       @id @default(cuid())
  type          QuestionType
  content       String
  answers       String[]
  correctAnswer String

  quiz   Quiz   @relation(fields: [quizId], references: [id])
  quizId String
  word   Word   @relation(fields: [wordId], references: [wordId])
  wordId String

  questionAttempts UserQuestionAttempt[]
}

model UserQuestionAttempt {
  id                String          @id @default(cuid())
  question          Question        @relation(fields: [questionId], references: [id])
  questionId        String
  userWordMastery   UserWordMastery @relation(fields: [userWordMasteryId], references: [id])
  userWordMasteryId String
  quizAttempt       QuizAttempt     @relation(fields: [quizAttemptId], references: [id])
  quizAttemptId     String
  answer            String
  correct           Boolean
  timeSpent         Int?
  attemptedAt       DateTime        @default(now())
}

// Enums
enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum Grade {
  NINE
  TEN
  ELEVEN
}

enum partOfSpeech {
  Noun
  Verb
  Adjective
}

enum QuizType {
  LEARN
  BASIC
  MASTERY
}

enum QuestionType {
  CONTEXT_DEFINITION // Context Sentences then Definition - LEARN
  DEFINITION_WORD // Definition then Word - QUIZ - BASIC
  SENTENCE_WORD // Sentence then Word - QUIZ - BASIC
  WORD_DEFINITION // Word then Definition - QUIZ - BASIC
  WORD_SPELLING // Sentence then Spelling - QUIZ - BASIC & MASTERY
}